<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- ALL logging goes to stderr — stdout is reserved for the MCP JSON-RPC protocol -->
    <appender name="STDERR" class="ch.qos.logback.core.ConsoleAppender">
        <target>System.err</target>
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="STDERR"/>
    </root>

    <!-- Reduce noise from Spring framework internals -->
    <logger name="org.springframework" level="WARN"/>
    <logger name="io.modelcontextprotocol" level="INFO"/>
    <logger name="com.vibeguard" level="DEBUG"/>
</configuration>
